        "# extraindo o caminho de poda da arvore anterior (model_tree)\n",
        "path = model_tree.cost_complexity_pruning_path(X_train_scaled, y_train)\n",
        "ccp_alphas, impurities = path.ccp_alphas, path.impurities\n",
        "\n",
        "# vamos ver quantos candidatos a alpha o algoritmo encontrou\n",
        "print(f\"Número de valores de alpha encontrados: {len(ccp_alphas)}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from sklearn.model_selection import cross_val_score\n",
        "\n",
        "alpha_loop_values = []\n",
        "\n",
        "# testamos uma amostra dos alfas para o codigo nao demorar demais (Pegamos 50 valores distribuidos para cobrir o intervalo)\n",
        "for alpha in np.linspace(ccp_alphas.min(), ccp_alphas.max(), 50):\n",
        "    model_pruned = DecisionTreeClassifier(random_state=42, ccp_alpha=alpha)\n",
        "    # cv=5 significa que ele divide o treino em 5 partes e testa 5 vezes\n",
        "    scores = cross_val_score(model_pruned, X_train_scaled, y_train, cv=5)\n",
        "    alpha_loop_values.append([alpha, np.mean(scores)])\n",
        "\n",
        "alpha_results = np.array(alpha_loop_values)\n",
        "# filtramos a matriz pegando apenas as linhas onde a coluna 0 (o alpha) é maior que 0.0005\n",
        "alphas_validos = alpha_results[alpha_results[:, 0] > 0.0005]\n",
        "# dentro desses alfas validos, pegamos a linha que tem a maior acuracia (coluna 1) e extraimos o valor do alpha dessa linha (coluna 0)\n",
        "best_alpha = alphas_validos[np.argmax(alphas_validos[:, 1]), 0]\n",
        "\n",
        "\n",
        "print(f\"O Melhor Alpha (forçando) encontrado foi: {best_alpha:.6f}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# treinando a arvore final com o melhor alpha\n",
        "tree_final = DecisionTreeClassifier(random_state=42, ccp_alpha=best_alpha)\n",
        "tree_final.fit(X_train_scaled, y_train)\n",
        "\n",
        "# calculando os novos erros\n",
        "ein_final = 1 - tree_final.score(X_train_scaled, y_train)\n",
        "eout_final = 1 - tree_final.score(X_test_scaled, y_test)\n",
        "\n",
        "print(f\"Novo Erro de Treinamento (Ein): {ein_final:.4f}\")\n",
        "print(f\"Novo Erro de Teste (Eout): {eout_final:.4f}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from sklearn.tree import plot_tree\n",
        "\n",
        "plt.figure(figsize=(30, 20)) \n",
        "\n",
        "# plotando a arvore podada (tree_final que criamos no passo anterior)\n",
        "plot_tree(tree_final, \n",
        "          feature_names=X_train.columns.tolist(), \n",
        "          class_names=['Normal', 'Estresse'],\n",
        "          filled=True,          # cores indicam a classe majoritaria\n",
        "          rounded=True,         # cantos arredondados para estetica\n",
        "          precision=2,          # casas decimais nos valores\n",
        "          fontsize=10)          # tamanho da fonte para leitura\n",
        "\n",
        "plt.title(f\"Árvore de Decisão Podada (Alpha = {best_alpha:.6f})\", fontsize=15)\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# fazendo as previsoes com a melhor arvore construida\n",
        "y_pred_tree = tree_final.predict(X_test_scaled)\n",
        "\n",
        "# exibindo as metricas \n",
        "print(\"=== Métricas de Qualidade (Árvore de Decisão Podada) ===\")\n",
        "print(f\"Acurácia: {accuracy_score(y_test, y_pred_tree):.4f}\\n\")\n",
        "print(classification_report(y_test, y_pred_tree, target_names=['Normal (0)', 'Estresse (1)']))\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 4.3"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from sklearn.ensemble import RandomForestClassifier\n",
        "\n",
        "# criando a floresta com 100 arvores (n_estimators)\n",
        "model_rf = RandomForestClassifier(n_estimators=100, random_state=42)\n",
        "model_rf.fit(X_train_scaled, y_train)\n",
        "\n",
        "# calculando os erros da floresta\n",
        "ein_rf = 1 - model_rf.score(X_train_scaled, y_train)\n",
        "eout_rf = 1 - model_rf.score(X_test_scaled, y_test)\n",
        "\n",
        "print(f\"Erro de Treinamento da Floresta (Ein): {ein_rf:.4f}\")\n",
        "print(f\"Erro de Teste da Floresta (Eout): {eout_rf:.4f}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "y_pred_rf = model_rf.predict(X_test_scaled)\n",
        "\n",
        "# exibindo as metricas \n",
        "print(\"=== Métricas de Qualidade (Random Forest) ===\")\n",
        "print(f\"Acurácia: {accuracy_score(y_test, y_pred_rf):.4f}\")\n",
        "print(classification_report(y_test, y_pred_rf, target_names=['Normal (0)', 'Estresse (1)']))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5. Arquitetura, Treinamento e Avaliação do SVM:"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 5.1 Otimização de Hiperparâmetros do SVM:\n",
        "\n",
        " O modelo SVM foi construído utilizando o kernel não-linear RBF. Para encontrar os melhores hiperparâmetros, empregamos o método GridSearchCV com validação cruzada (CV=5). O grid explorou diferentes valores de penalidade de margem (C: 0.1, 1, 10) e coeficientes do kernel (gamma: scale, auto, 0.1, 1), buscando o ponto ótimo de separação das classes de estresse\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "\n",
        "from sklearn.svm import SVC\n",
        "from sklearn.model_selection import GridSearchCV\n",
        "\n",
        "# definindo os parsmetros para testar na validacao cruzada\n",
        "param_grid = {\n",
        "    'C': [0.1, 1, 10],\n",
        "    'gamma': ['scale', 'auto', 0.1, 1],\n",
        "    'kernel': ['rbf']\n",
        "}\n",
        "\n",
        "# configurando o GridSearchCV (cv=5 define os 5 folds do cross validation)\n",
        "grid_search = GridSearchCV(SVC(), param_grid, cv=5, scoring='accuracy', n_jobs=-1)\n",
        "\n",
        "# usamos os dados escalonados (X_train_scaled) que tratamos no comeco do projeto\n",
        "grid_search.fit(X_train_scaled, y_train)\n",
        "\n",
        "# extraindo o melhor modelo encontrado\n",
        "best_svm = grid_search.best_estimator_\n",
        "print(f\"Melhores parâmetros encontrados: {grid_search.best_params_}\\n\")\n",
        "\n",
        "\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# calculando os erros (Ein e Eout) com o melhor modelo\n",
        "ein_svm = 1 - best_svm.score(X_train_scaled, y_train)\n",
        "eout_svm = 1 - best_svm.score(X_test_scaled, y_test)\n",
        "\n",
        "print(f\"Erro de Treinamento SVM (Ein): {ein_svm:.4f}\")\n",
        "print(f\"Erro de Teste SVM (Eout): {eout_svm:.4f}\\n\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Dada a não-linearidade do comportamento do sistema elétrico, o SVM foi estruturado utilizando o kernel RBF (Radial Basis Function). O algoritmo GridSearchCV determinou que o custo de penalidade C=10 oferecia o equilíbrio ideal (Trade-off Bias-Variance). Um valor de C elevado forçou o modelo a respeitar uma margem rígida, porém a similaridade notável entre o Erro dentro da amostra ($E_in=0.0816$) e o Erro fora da amostra ($E_out=0.0894$) confirma a ausência de overfitting, atestando uma classificação altamente confiável."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 5.2 Avaliação Teórica do Erro de Teste ($E_out$):\n",
        "\n",
        "Para atestar a robustez do SVM de acordo com a teoria da aprendizagem, verificamos a limitação teórica do erro esperado. A teoria dita que o limite superior do Erro de Teste ($E_out$) está diretamente relacionado à proporção de Vetores de Suporte em relação ao total de exemplos de treino. Calculamos este limite para garantir que a margem do modelo está generalizando de forma saudável\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# calculando o Eout esperado pela teoria (baseado nos vetores de suporte)\n",
        "n_support_vectors = sum(best_svm.n_support_)\n",
        "n_total = len(X_train_scaled)\n",
        "e_out_esperado = n_support_vectors / n_total\n",
        "\n",
        "print(f\"Número de Vetores de Suporte: {n_support_vectors}\")\n",
        "print(f\"Eout esperado pela teoria: {e_out_esperado:.4f}\")\n",
        "print(f\"Eout real obtido: {eout_svm:.4f}\\n\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# computando as metricas \n",
        "y_pred_svm = best_svm.predict(X_test_scaled)\n",
        "print(\"=== Métricas de Qualidade (Melhor SVM) ===\")\n",
        "print(classification_report(y_test, y_pred_svm, target_names=['Normal (0)', 'Estresse (1)']))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 6. Conclusão:\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Conclui-se que o objetivo foi plenamente atendido. O sistema desenvolvido não apenas classifica o estresse da rede com precisão superior a 90%, como também respeita os limites teóricos de generalização. Os modelos resultantes oferecem uma base sólida para a predição de anomalias, mitigando riscos operativos e contribuindo para a estabilidade da matriz elétrica regional."
      ]
